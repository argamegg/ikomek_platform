{
  "expo": {
    "name": "iKOMEK Mobile App",
    "slug": "ikomek-mobile-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "ikomek-mobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.ikomekmobileapp"
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "package": "com.anonymous.ikomekmobileapp"
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#000"
        }
      ],
      "@maplibre/maplibre-react-native"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
