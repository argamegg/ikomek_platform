{
  "expo": {
    "name": "iKOMEK 109",
    "slug": "ikomek-109",
    "version": "1.0.0",
    "owner": "argamegg",
    "orientation": "portrait",
    "icon": "./assets/images/app-icon.png",
    "splash": {
      "image": "./assets/splash-logo.png",
      "backgroundColor": "#FFFFFF",
      "resizeMode": "contain"
    },
    "scheme": "ikomek109",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "icon": "./assets/images/app-icon.png",
      "supportsTablet": true,
      "bundleIdentifier": "kz.ikomek.mobile",
      "infoPlist": {
        "NSLocalNetworkUsageDescription": "Allow iKOMEK 109 to connect to the local development server.",
        "NSBonjourServices": [
          "_expo._tcp",
          "_react-native-packager._tcp"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/app-icon.png",
        "backgroundColor": "#000000"
      },
      "edgeToEdgeEnabled": true,
      "package": "kz.ikomek.mobile"
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#FFFFFF"
        }
      ],
      "@maplibre/maplibre-react-native",
      "expo-video",
      "expo-web-browser",
      "@clerk/expo",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "backendUrl": "https://ikomekservice.kz",
      "eas": {
        "projectId": "40989f85-c02c-44eb-8c65-9ce231bd0de9"
      }
    }
  }
}
