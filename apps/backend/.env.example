# Request geo-fence
ASTANA_CENTER_LAT=51.1282
ASTANA_CENTER_LNG=71.4306
ASTANA_MAX_RADIUS_KM=60

# CORS
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8081,http://127.0.0.1:8081
CORS_ORIGIN_REGEX=https?://(localhost|127\.0\.0\.1|192\.168\.\d+\.\d+):\d+

# AI assistant / Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_API_BASE=https://generativelanguage.googleapis.com/v1beta
GEMINI_MAX_OUTPUT_TOKENS=650
